  clientes             clientes               @relation(fields: [cliente_id], references: [id], onUpdate: NoAction, map: "fk_agendamentos_cliente")
  avaliacoes           avaliacoes?
  transacoes           transacoes[]

  @@index([barbeiro_id, data_hora_inicio], map: "idx_agendamentos_barbeiro_data")
  @@index([cliente_id], map: "idx_agendamentos_cliente")
  @@index([data_hora_inicio], map: "idx_agendamentos_data")
  @@index([status], map: "idx_agendamentos_status")
}

