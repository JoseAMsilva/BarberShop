}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model agendamento_servicos {
  id             Int          @id @default(autoincrement()) @db.UnsignedInt
  agendamento_id String       @db.Char(36)
  servico_id     String       @db.Char(36)
  preco_cobrado  Decimal      @db.Decimal(10, 2)
  agendamentos   agendamentos @relation(fields: [agendamento_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_as_agendamento")
  servicos       servicos     @relation(fields: [servico_id], references: [id], onUpdate: NoAction, map: "fk_as_servico")

  @@unique([agendamento_id, servico_id], map: "uk_agendamento_servico")
  @@index([servico_id], map: "idx_as_servico")
}

